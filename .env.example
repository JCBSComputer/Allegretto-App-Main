# AdMob IDs (get from https://apps.admob.com)
ADMOB_PUBLISHER_ID=your_publisher_id_here
ADMOB_BANNER_ID=your_banner_id_here
ADMOB_INTERSTITIAL_ID=your_interstitial_id_here
ADMOB_REWARDED_ID=your_rewarded_id_here
ADMOB_WEB_SLOT_ID=your_web_slot_id_here

# FCM VAPID Key (from Firebase Console > Cloud Messaging > Web configuration)
FCM_VAPID_KEY=your_vapid_key_here

# Admin password for developer upload deletion
ADMIN_PASSWORD=your_admin_password_here
